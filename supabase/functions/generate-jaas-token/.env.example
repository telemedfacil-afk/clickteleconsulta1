# JaaS (8x8.vc) Private Key for JWT signing (RS256)
# Paste the full PEM content (including BEGIN/END headers) as a single value.
# In Supabase Dashboard: Settings → Edge Functions → Secrets → add JAAS_PRIVATE_KEY
# In local dev (supabase/functions/.env): paste full PEM keeping newlines or use base64.
JAAS_PRIVATE_KEY=<sua-chave-privada-PEM-aqui>

# The following are automatically injected by Supabase Edge Functions runtime:
# SUPABASE_URL=<set-by-runtime>
# SUPABASE_SERVICE_ROLE_KEY=<set-by-runtime>
# SUPABASE_ANON_KEY=<set-by-runtime>
